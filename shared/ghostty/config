# Ghostty — matches the One Dark/Light Terminal.app profiles.
# Themes live in ./themes; Ghostty follows macOS appearance natively,
# so light/dark switching needs no theme-sync wiring.
theme = light:one-light,dark:one-dark

# Same face as Terminal.app (its "BlexMonoNF-Medium" is the PostScript name;
# the family is "BlexMono Nerd Font", i.e. IBM Plex Mono): full-width NF
# variant, Medium at 15 (a notch lighter than SemiBold, heavier than Regular).
font-family = BlexMono Nerd Font
font-style = Medium
font-size = 15
adjust-cell-height = 10%

# Match the Terminal.app profile geometry and cursor.
window-width = 120
window-height = 34
cursor-style = block
cursor-style-blink = false
