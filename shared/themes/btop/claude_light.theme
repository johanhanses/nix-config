# Claude Light — warm parchment, coral accent (no purple)

# Main background, empty for terminal default, need to be empty if you want transparent background
theme[main_bg]="#e6e0d1"

# Main text color
theme[main_fg]="#262624"

# Title color for boxes
theme[title]="#262624"

# Highlight color for keyboard shortcuts
theme[hi_fg]="#c96442"

# Background color of selected item in processes box
theme[selected_bg]="#d8d0bc"

# Foreground color of selected item in processes box
theme[selected_fg]="#c96442"

# Color of inactive/disabled text
theme[inactive_fg]="#7a786e"

# Color of text appearing on top of graphs, i.e uptime and current network graph scaling
theme[graph_text]="#5f5b51"

# Background color of the percentage meters
theme[meter_bg]="#d8d0bc"

# Misc colors for processes box including mini cpu graphs, details memory graph and details status text
theme[proc_misc]="#5f5b51"

# CPU, Memory, Network, Proc box outline colors
theme[cpu_box]="#c96442" #Coral
theme[mem_box]="#4f6d2f" #Olive
theme[net_box]="#8c4a5c" #Rose
theme[proc_box]="#426187" #Slate

# Box divider line and small boxes line color
theme[div_line]="#c7c1ae"

# Temperature graph color (Olive -> Gold -> Red)
theme[temp_start]="#4f6d2f"
theme[temp_mid]="#8a661a"
theme[temp_end]="#9e3a27"

# CPU graph colors (Sage -> Slate)
theme[cpu_start]="#3c6d5c"
theme[cpu_mid]="#426187"
theme[cpu_end]="#547397"

# Mem/Disk free meter (Rose -> Slate)
theme[free_start]="#8c4a5c"
theme[free_mid]="#6f5a73"
theme[free_end]="#426187"

# Mem/Disk cached meter (Sage -> Slate)
theme[cached_start]="#3c6d5c"
theme[cached_mid]="#4f8070"
theme[cached_end]="#547397"

# Mem/Disk available meter (Gold -> Coral)
theme[available_start]="#8a661a"
theme[available_mid]="#9c5124"
theme[available_end]="#c96442"

# Mem/Disk used meter (Olive -> Sage)
theme[used_start]="#4f6d2f"
theme[used_mid]="#486d4b"
theme[used_end]="#3c6d5c"

# Download graph colors (Gold -> Red)
theme[download_start]="#8a661a"
theme[download_mid]="#9c5124"
theme[download_end]="#9e3a27"

# Upload graph colors (Olive -> Sage)
theme[upload_start]="#4f6d2f"
theme[upload_mid]="#486d4b"
theme[upload_end]="#3c6d5c"

# Process box color gradient for threads, mem and cpu usage (Slate -> Rose)
theme[process_start]="#426187"
theme[process_mid]="#6f5a73"
theme[process_end]="#8c4a5c"
