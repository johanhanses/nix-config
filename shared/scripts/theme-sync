#!/bin/sh
# theme-sync — align terminal-adjacent tools with the current macOS appearance.
# Invoked by the theme-watch agent (on appearance change) and tmux <prefix>+r.
#
# Claude Light (light) / Claude Dark (dark):
#   - Terminal.app  : switch the profile (requires the two profiles imported)
#   - btop          : rewrite color_theme in the mutable btop.conf
#   - tmux          : source the matching status-bar theme
#   - Mattermost    : push a custom theme via REST (needs the private config)
#   - bat / fzf / delta / nvim self-follow (ANSI palette / auto-dark-mode)
set -u

# Detect appearance. `defaults read -g AppleInterfaceStyle` is unreliable in
# non-interactive / launchd contexts (cfprefsd returns "does not exist" even in
# dark mode), so use System Events, falling back to defaults.
detect_dark() {
  d=$(osascript -e 'tell application "System Events" to tell appearance preferences to get dark mode' 2>/dev/null)
  case "$d" in
    true) echo dark ;;
    false) echo light ;;
    *) if defaults read -g AppleInterfaceStyle 2>/dev/null | grep -qi dark; then echo dark; else echo light; fi ;;
  esac
}

if [ "$(detect_dark)" = "dark" ]; then
  MODE=dark
  TERM_PROFILE="Claude Dark"
  BTOP_THEME="claude_dark"
  TMUX_THEME="claude-dark"
else
  MODE=light
  TERM_PROFILE="Claude Light"
  BTOP_THEME="claude_light"
  TMUX_THEME="claude-light"
fi

# Terminal.app — set default + all open windows to the matching profile.
if pgrep -x Terminal >/dev/null 2>&1; then
  osascript <<EOF 2>/dev/null || true
tell application "Terminal"
  set default settings to settings set "$TERM_PROFILE"
  set startup settings to settings set "$TERM_PROFILE"
  repeat with w in windows
    try
      set current settings of tabs of w to settings set "$TERM_PROFILE"
    end try
  end repeat
end tell
EOF
fi

# btop — rewrite the theme in the mutable conf.
BTOP_CONF="$HOME/.config/btop/btop.conf"
if [ -f "$BTOP_CONF" ]; then
  /usr/bin/sed -i '' "s/^color_theme = .*/color_theme = \"$BTOP_THEME\"/" "$BTOP_CONF" 2>/dev/null || true
fi

# tmux — source the matching status-bar theme.
if command -v tmux >/dev/null 2>&1 && tmux info >/dev/null 2>&1; then
  tmux source-file "$HOME/.config/tmux/themes/$TMUX_THEME.tmux" >/dev/null 2>&1 || true
fi

# Mattermost Desktop via REST — push a Claude-warm custom theme (user + teams).
MM_CFG="$HOME/Repos/github.com/johanhanses/dotfiles-private/mattermost/config"
CLAUDE_DARK='{"sidebarBg":"#1f1e1d","sidebarText":"#c9c5b9","sidebarUnreadText":"#e8e6dc","sidebarTextHoverBg":"#3a3937","sidebarTextActiveBorder":"#c96442","sidebarTextActiveColor":"#e8e6dc","sidebarHeaderBg":"#1f1e1d","sidebarHeaderTextColor":"#e8e6dc","onlineIndicator":"#90a870","awayIndicator":"#d0a45c","dndIndicator":"#e0705f","mentionBg":"#c96442","mentionColor":"#faf9f5","centerChannelBg":"#262624","centerChannelColor":"#e8e6dc","newMessageSeparator":"#c96442","linkColor":"#d97757","buttonBg":"#c96442","buttonColor":"#faf9f5","errorTextColor":"#e0705f","mentionHighlightBg":"#4a453e","mentionHighlightLink":"#d97757","codeTheme":"monokai","sidebarTeamBarBg":"#1f1e1d"}'
CLAUDE_LIGHT='{"sidebarBg":"#e6e0d1","sidebarText":"#262624","sidebarUnreadText":"#1f1e1d","sidebarTextHoverBg":"#d8d0bc","sidebarTextActiveBorder":"#c96442","sidebarTextActiveColor":"#1f1e1d","sidebarHeaderBg":"#ddd6c5","sidebarHeaderTextColor":"#262624","onlineIndicator":"#4f6d2f","awayIndicator":"#8a661a","dndIndicator":"#9e3a27","mentionBg":"#c96442","mentionColor":"#faf9f5","centerChannelBg":"#efe9dc","centerChannelColor":"#262624","newMessageSeparator":"#c96442","linkColor":"#9c4c28","buttonBg":"#c96442","buttonColor":"#faf9f5","errorTextColor":"#9e3a27","mentionHighlightBg":"#e0d3b6","mentionHighlightLink":"#9c4c28","codeTheme":"github","sidebarTeamBarBg":"#ddd6c5"}'
if [ -f "$MM_CFG" ] && command -v jq >/dev/null 2>&1; then
  # shellcheck source=/dev/null
  . "$MM_CFG"
  if [ -n "${MATTERMOST_URL:-}" ] && [ -n "${MATTERMOST_TOKEN:-}" ]; then
    if [ "$MODE" = dark ]; then MM_THEME="$CLAUDE_DARK"; else MM_THEME="$CLAUDE_LIGHT"; fi
    MM_UID=$(curl -sf -H "Authorization: Bearer $MATTERMOST_TOKEN" "$MATTERMOST_URL/api/v4/users/me" 2>/dev/null | jq -r '.id' 2>/dev/null || true)
    if [ -n "${MM_UID:-}" ] && [ "$MM_UID" != null ]; then
      MM_PAYLOAD=$(jq -n --arg uid "$MM_UID" --arg theme "$MM_THEME" '[{user_id:$uid,category:"theme",name:"",value:$theme}]')
      for TID in $(curl -sf -H "Authorization: Bearer $MATTERMOST_TOKEN" "$MATTERMOST_URL/api/v4/users/$MM_UID/teams" 2>/dev/null | jq -r '.[].id' 2>/dev/null); do
        MM_PAYLOAD=$(printf '%s' "$MM_PAYLOAD" | jq --arg uid "$MM_UID" --arg tid "$TID" --arg theme "$MM_THEME" '. + [{user_id:$uid,category:"theme",name:$tid,value:$theme}]')
      done
      curl -sf -X PUT -H "Authorization: Bearer $MATTERMOST_TOKEN" -H "Content-Type: application/json" \
        --data "$MM_PAYLOAD" "$MATTERMOST_URL/api/v4/users/$MM_UID/preferences" >/dev/null 2>&1 \
        && echo "mattermost: synced ($MODE)" || true
    fi
  fi
fi

echo "theme-sync: $MODE"
